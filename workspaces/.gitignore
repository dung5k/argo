# Chặn toàn bộ nội dung trong thư mục này
*

# Nhưng không chặn các thư mục con (để Git có thể đi vào tìm file hợp lệ)
!*/

# VÀ KHÔNG CHẶN các loại file cấu hình (json) và file thành tích (json, txt, md)
!*.json
!*.txt
!*.md
!.gitignore

# KHOÁ TOÀN BỘ DATA NẶNG VÀ TENSORS LẠI BẤT KỂ ĐỊNH DẠNG CÓ LÀ GÌ NỮA
data/*
raw/*
tensors/*
trading_logs/*
*.parquet
*.npy
*.pth
*.pkl
