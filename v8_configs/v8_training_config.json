{
  "system": {
    "version": "v8.0.0",
    "strict_no_repaint": true,
    "log_level": "DEBUG"
  },
  "data": {
    "symbol": "LTCUSD",
    "timeframes": ["M15", "H1", "H4"],
    "train_data_path": "data/LTCUSD_M15.csv",
    "test_data_path": "temp/test_data_m15.csv"
  },
  "fractal_params": {
    "window_size": 5,
    "latency_candles": 2,
    "volume_multiplier_threshold": 1.2,
    "ma_volume_period": 20
  },
  "nlp_tokenizer_params": {
    "max_sequence_length": 50,
    "vocabulary": [
      "HH_FAST", "HH_NORMAL", "HH_SLOW",
      "HL_FAST", "HL_NORMAL", "HL_SLOW",
      "LH_FAST", "LH_NORMAL", "LH_SLOW",
      "LL_FAST", "LL_NORMAL", "LL_SLOW",
      "BOS_UP_FAST", "BOS_UP_NORMAL", "BOS_UP_SLOW",
      "BOS_DN_FAST", "BOS_DN_NORMAL", "BOS_DN_SLOW",
      "CHOCH_UP_FAST", "CHOCH_UP_NORMAL", "CHOCH_UP_SLOW",
      "CHOCH_DN_FAST", "CHOCH_DN_NORMAL", "CHOCH_DN_SLOW",
      "FAKE_BOS_FAST", "FAKE_BOS_NORMAL", "FAKE_BOS_SLOW"
    ],
    "pad_token": "<PAD>"
  },
  "transformer_params": {
    "embedding_dim": 64,
    "num_heads": 4,
    "num_layers": 3,
    "dropout": 0.1,
    "context_dim": 128,
    "num_classes": 5
  },
  "training_loop": {
    "batch_size": 32,
    "learning_rate": 0.001,
    "epochs": 100,
    "optimizer": "AdamW",
    "loss_function": "CrossEntropy"
  }
}
